# =============================================================================
#  Interview Copilot — API-light environment template
#
#  Every heavy component (LLM / embedding / reranker / ASR) runs through a
#  cloud API. Zero local model downloads, no GPU needed, ~5 min to first
#  chat once the keys are filled.
#
#  Minimum viable setup:
#    1. Pick one LLM provider, fill its key in § 4.
#    2. Pick one embedding+rerank+ASR provider, fill its key in § 5.
#       SiliconFlow alone covers all three.
#    3. Generate SECRET_KEY in § 1.
#
#  Usage:
#    cp .env.example.lite .env        # Linux / macOS
#    Copy-Item .env.example.lite .env # Windows PowerShell
#
#  Never commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# § 1. Security  [required]
# -----------------------------------------------------------------------------
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SECRET_KEYS_OLD=


# -----------------------------------------------------------------------------
# § 2. Core service URLs
#     Defaults match the bundled docker-compose containers.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_copilot
REDIS_URL=redis://localhost:6379/0
MILVUS_URI=http://localhost:19530

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Reverse-proxy trust list — leave EMPTY in dev. In prod set to the
# nginx/ALB IP (e.g. 127.0.0.1) so per-IP rate-limit + IP-lockout
# don't collapse onto the proxy IP. See .env.example for details.
TRUSTED_PROXIES=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080


# -----------------------------------------------------------------------------
# § 3. Object storage (defaults match bundled MinIO)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=interview-copilot-bucket


# -----------------------------------------------------------------------------
# § 3.5. SMTP — email verification codes
#     Leave SMTP_HOST empty in dev → codes print to backend stdout.
#     Filled → real emails sent AND body mirrored to log for traceability.
#     Provider setup is identical to .env.example — see that file for the
#     Gmail / 163 / QQ / Outlook quick reference.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Interview Copilot <noreply@example.com>
SMTP_USE_TLS=true


# -----------------------------------------------------------------------------
# § 3.6. LangSmith — LLM call tracing (optional)
#     https://smith.langchain.com → Settings → API Keys
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=interview-copilot-dev
LANGSMITH_TRACING=false


# -----------------------------------------------------------------------------
# § 4. LLM provider keys  [fill at least one]
#     Empty keys are skipped silently.
# -----------------------------------------------------------------------------

# DeepSeek — cheap, strong, China-friendly. Recommended starter.
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenAI
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Alibaba DashScope (Qwen)
# https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# Moonshot (Kimi)
# https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# Zhipu (GLM)
# https://bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# Xiaomi MiMo
MIMO_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# NVIDIA API Catalog — hosts open-weights mirrors (Llama, Qwen, Gemma, …).
# https://build.nvidia.com/
# Only NVIDIA_API_KEY is required; the api_base default ships in
# services/model_sources/providers.py and model discovery uses /v1/models.
NVIDIA_API_KEY=


# -----------------------------------------------------------------------------
# § 5. Embedding / Reranker / ASR keys  [fill at least one]
#     In API-light mode all three run remotely. SiliconFlow alone covers
#     every role and has a usable free tier.
# -----------------------------------------------------------------------------

# SiliconFlow — embedding + reranker + ASR in one account.
# https://siliconflow.cn  (register → copy key)
SILICONFLOW_API_KEY=

# Jina AI — embedding + reranker.
# https://jina.ai/
JINA_API_KEY=

# Cohere — reranker.
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Note: DASHSCOPE_API_KEY from § 4 also works for embeddings.


# -----------------------------------------------------------------------------
# § 6. Strongly recommended external services
#     Technically optional with graceful fallback, but the UX hit is real.
# -----------------------------------------------------------------------------

# LlamaCloud LlamaParse — high-quality PDF/DOCX parsing for resumes and
# the knowledge library. Empty → falls back to PyMuPDF, which mangles
# multi-column or scanned PDFs.
# Sign up:  https://cloud.llamaindex.ai/api-key  (free 1k pages/month)
LLAMA_CLOUD_API_KEY=

# Tavily — web search tool used by Agent mode. Empty → web_search is
# disabled.
# Sign up:  https://tavily.com/  (free 1k searches/month)
TAVILY_API_KEY=


# -----------------------------------------------------------------------------
# § 7. Model role assignment
#     API-light mode defaults all three subsystems to SiliconFlow.
# -----------------------------------------------------------------------------

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_PROVIDER=siliconflow
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── ASR (audio transcription) ───────────────────────────────────────────────
TRANSCRIPTION_PROVIDER=siliconflow
TRANSCRIPTION_MODEL=FunAudioLLM/SenseVoiceSmall

# ── Speaker diarization ─────────────────────────────────────────────────────
# auto      = enable Pyannote when ASR is local_whisperx; otherwise off.
# pyannote  = HYBRID mode: cloud ASR + local Pyannote (~17 MB). The cloud
#             ASR must return word-level timestamps (openai/whisper-1 does).
#             Run once: python scripts/init_models.py --only diarization
# none      = always single-speaker transcript.
DIARIZATION_MODE=auto

# ── TTS ─────────────────────────────────────────────────────────────────────
TTS_DEFAULT_VOICE=zh-CN-YunxiNeural

# ── LLM role routing ────────────────────────────────────────────────────────
# Three user-facing roles (primary / agent / mock_interview, plus internal
# back-compat alias ``fast``) map to specific ``{provider}/{model_id}``
# profile ids — picked from the live vendor catalog. The assignment is
# persisted per user in ``users.model_selection_json`` (Postgres) and
# edited from the frontend "Models" page. No env var needed here.


# -----------------------------------------------------------------------------
# § 8. Error reporting (Sentry — optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1


# -----------------------------------------------------------------------------
# § 9. What you DON'T need in API-light mode
# -----------------------------------------------------------------------------
# In API-light mode you do NOT need to:
#   - Run python scripts/init_models.py (it's a no-op when providers are remote)
#   - Configure HF_ENDPOINT
#   - Have a GPU
#   - Reserve disk for model weights
#
# To switch to local-models build later, copy from .env.example instead.
