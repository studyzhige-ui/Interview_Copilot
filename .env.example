# ┌─────────────────────────────────────────────────────────────────────────┐
# │  Interview Copilot — Environment Configuration                        │
# │  Copy to .env and fill in your values. Never commit .env to git.      │
# └─────────────────────────────────────────────────────────────────────────┘

# ═══════════════════════════════════════════════════════════════════════════
# 1. REQUIRED API KEYS
# ═══════════════════════════════════════════════════════════════════════════
# At minimum, you need ONE LLM provider API key to run the system.
# DeepSeek is the default and recommended provider.
#
# Get your API key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key

# ═══════════════════════════════════════════════════════════════════════════
# 2. OPTIONAL API KEYS
# ═══════════════════════════════════════════════════════════════════════════

# LlamaCloud — enables LlamaParse for high-quality PDF/DOCX parsing.
# Without this, the system falls back to PyMuPDF (still works, just less accurate on complex layouts).
# Get your key at: https://cloud.llamaindex.ai/api-key
LLAMA_CLOUD_API_KEY=

# NVIDIA API Catalog — provides access to additional LLM models (Llama, Gemma, Qwen, etc.)
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Tavily — enables the agent's web search tool.
# Without this key, the web_search tool is simply disabled.
# Get your key at: https://tavily.com/
TAVILY_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# 3. CORE SERVICES
# ═══════════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_copilot
SECRET_KEY=change-me-for-local-development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
REDIS_URL=redis://localhost:6379/0

# S3-compatible storage (defaults match docker-compose local MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=interview-copilot-bucket

# ═══════════════════════════════════════════════════════════════════════════
# 4. LOCAL MODEL SELECTION
# ═══════════════════════════════════════════════════════════════════════════
# These models run LOCALLY on your machine (downloaded from HuggingFace).
# Run `python scripts/init_models.py` to auto-download all selected models.
#
# HuggingFace mirror (use official endpoint outside China):
#   Default (China mirror): https://hf-mirror.com
#   Official:               https://huggingface.co
HF_ENDPOINT=https://hf-mirror.com

# ── Embedding Model ──────────────────────────────────────────────────────
# Used for RAG vector search. Must match EMBEDDING_DIM.
# Run: python scripts/init_models.py --only embedding
#
# Recommended options:
#   BAAI/bge-m3           (dim=1024, ~1.06 GB)  — Best for Chinese+English, default
#   BAAI/bge-large-zh-v1.5 (dim=1024, ~620 MB)  — Chinese-focused, smaller
#   BAAI/bge-small-en-v1.5 (dim=384,  ~64 MB)   — English only, very fast, low VRAM
#   sentence-transformers/all-MiniLM-L6-v2 (dim=384, ~86 MB) — Lightweight English
#   intfloat/multilingual-e5-large (dim=1024, ~1.06 GB) — Strong multilingual
EMBEDDING_MODEL_ID=BAAI/bge-m3
EMBEDDING_DIM=1024
# Device: "auto" (detect GPU), "cuda", or "cpu"
EMBEDDING_DEVICE=auto

# ── Reranker Model ────────────────────────────────────────────────────────
# Used for reranking retrieved documents (cross-encoder).
# Run: python scripts/init_models.py --only reranker
#
# Recommended options:
#   BAAI/bge-reranker-base    (~530 MB)  — Lightweight, fast, good accuracy, default
#   BAAI/bge-reranker-large   (~1.06 GB) — Higher accuracy, more VRAM
#   BAAI/bge-reranker-v2-m3   (~1.08 GB) — Best quality, multilingual, largest
RERANKER_MODEL_ID=BAAI/bge-reranker-base

# ── Whisper (Speech-to-Text) Model ───────────────────────────────────────
# Used for interview audio transcription. Uses CTranslate2 format (faster-whisper).
# Run: python scripts/init_models.py --only whisper
#
# Recommended options (faster-whisper / CTranslate2 format):
#   Systran/faster-whisper-large-v2  (~3.09 GB) — Best accuracy, default
#   Systran/faster-whisper-medium    (~1.5 GB)  — Good balance
#   Systran/faster-whisper-small     (~486 MB)  — Fast, lower accuracy
#   Systran/faster-whisper-base      (~148 MB)  — Very fast, lowest accuracy
WHISPER_MODEL_ID=Systran/faster-whisper-large-v2

# ── Speaker Diarization Model ────────────────────────────────────────────
# Used for identifying different speakers in interview recordings.
# Run: python scripts/init_models.py --only diarization
#
# NOTE: The community model below does NOT require a HuggingFace token.
# The official pyannote models (pyannote/speaker-diarization-3.1) require
# accepting the license at https://hf.co/pyannote/speaker-diarization-3.1
# and setting HF_TOKEN in your environment.
#
# Options:
#   pyannote-community/speaker-diarization-community-1  — No token needed, default
#   pyannote/speaker-diarization-3.1                    — Better accuracy, needs HF_TOKEN
DIARIZATION_MODEL_ID=pyannote-community/speaker-diarization-community-1

# ── TTS Voice ─────────────────────────────────────────────────────────────
# Voice for text-to-speech in mock interviews (edge-tts).
# Full voice list: https://speech.platform.bing.com/consumer/speech/synthesize/readaloud/voices/list
TTS_DEFAULT_VOICE=zh-CN-YunxiNeural

# ═══════════════════════════════════════════════════════════════════════════
# 5. LLM MODEL ROUTING (cloud API models)
# ═══════════════════════════════════════════════════════════════════════════
# The system uses role-based model routing. You can change which model
# serves each role at runtime from the frontend, or by editing
# data/runtime/model_selection.json.
#
# Roles:
#   primary — Main chat and RAG responses
#   fast    — Internal tasks (rewriting, routing, metadata annotation)
#   agent   — Tool-calling agent workflows (must support function calling)
#
# Available DeepSeek models (recommended):
#   deepseek-v4-flash  — Fast, 1M context, function calling ✓ (default for primary/fast)
#   deepseek-v4-pro    — Stronger reasoning, function calling ✓ (default for agent)
#
# Available NVIDIA models (requires NVIDIA_API_KEY):
#   nvidia-meta-llama-3.1-8b, nvidia-qwen2.5-coder-32b, etc.
#
# Default routing (no need to change for most users):
MODEL_SELECTION_FILE=

# ═══════════════════════════════════════════════════════════════════════════
# 6. MILVUS VECTOR STORE
# ═══════════════════════════════════════════════════════════════════════════
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=interview_copilot_rag
MILVUS_SIMILARITY_METRIC=IP
MILVUS_DENSE_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_HNSW_EF_SEARCH=64
MEMORY_MILVUS_COLLECTION=interview_copilot_memory
MEMORY_VECTOR_TOP_K=8
MEMORY_LEXICAL_TOP_K=12
MEMORY_FINAL_TOP_K=3
MEMORY_BACKFILL_ON_STARTUP=true
RESUME_MILVUS_COLLECTION=interview_copilot_resume

# ═══════════════════════════════════════════════════════════════════════════
# 7. RAG AND AGENT TUNING (advanced, defaults work well)
# ═══════════════════════════════════════════════════════════════════════════
VECTOR_TOP_K=8
BM25_TOP_K=8
FUSION_TOP_K=6
RERANK_TOP_N=5
RAG_MIN_SCORE=0.5
RAG_FALLBACK_MIN_SCORE=0.02
RAG_LEXICAL_FALLBACK_MIN_OVERLAP=0.35
AGENT_MAX_STEPS=25
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_TEMPERATURE=0.2
AGENT_MAX_RUNTIME_SECONDS=180
AGENT_MAX_TOTAL_TOKENS=200000
AGENT_MAX_RESPONSE_TOKENS=4096
AGENT_MAX_TOOL_CALLS=50
AGENT_MAX_CALLS_PER_TOOL=8
AGENT_TOOL_SCHEMA_STRICT=true
AGENT_MAX_TOOL_ARG_CHARS=4000
AGENT_PERSIST_THRESHOLD=30000
AGENT_TURN_BUDGET_CHARS=100000
AGENT_PERSIST_PREVIEW_SIZE=1500

# ═══════════════════════════════════════════════════════════════════════════
# 8. RUNTIME DATA PATHS (leave blank to use defaults under data/)
# ═══════════════════════════════════════════════════════════════════════════
APP_DATA_DIR=
DB_DIR=
CHROMA_DB_DIR=
DOCSTORE_DIR=
CACHE_DIR=
LOG_DIR=
EVAL_DIR=
STORAGE_DIR=

# ═══════════════════════════════════════════════════════════════════════════
# 9. EVALUATION (optional, for running the evaluation suite)
# ═══════════════════════════════════════════════════════════════════════════
EVAL_LIMIT=200
EVAL_CONCURRENCY=4
EVAL_RELEVANCE_THRESHOLD=0.15
EVAL_TIMEOUT_SECONDS=60
EVAL_FORCE_REBUILD=0
RAGAS_CHUNK_SIZE=10
RAGAS_MAX_WORKERS=32

# ═══════════════════════════════════════════════════════════════════════════
# 10. DATABASE CONNECTION POOL
# ═══════════════════════════════════════════════════════════════════════════
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# Lever job-search tool (for agent web search)
LEVER_API_BASE=https://api.lever.co/v0
LEVER_SITES=openai
LEVER_DEFAULT_LIMIT=30
