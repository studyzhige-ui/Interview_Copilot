# Copy this file to .env for local development. Never commit real secrets.

# Core service
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_copilot
SECRET_KEY=change-me-for-local-development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
REDIS_URL=redis://localhost:6379/0
HF_ENDPOINT=https://hf-mirror.com
APP_DATA_DIR=

# LLM providers
DEEPSEEK_API_KEY=your_deepseek_api_key
# Defaults are DeepSeek V4 Flash for chat/fast paths and DeepSeek V4 Pro for agent/tool paths.
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_optional
NVIDIA_API_KEY=your_nvidia_api_key_optional
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct
MODEL_SELECTION_FILE=

# Object storage. Defaults match docker-compose local MinIO.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=interview-copilot-bucket

# Runtime data paths. Leave blank to use APP_DATA_DIR subdirectories.
DB_DIR=
CHROMA_DB_DIR=
DOCSTORE_DIR=
CACHE_DIR=
LOG_DIR=
EVAL_DIR=
STORAGE_DIR=

# Milvus vector store
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=interview_copilot_rag
MILVUS_SIMILARITY_METRIC=IP
MILVUS_DENSE_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_HNSW_EF_SEARCH=64
MEMORY_MILVUS_COLLECTION=interview_copilot_memory
MEMORY_VECTOR_TOP_K=8
MEMORY_LEXICAL_TOP_K=12
MEMORY_FINAL_TOP_K=3
MEMORY_BACKFILL_ON_STARTUP=true

# Local models
EMBEDDING_DEVICE=auto
EMBEDDING_MODEL_ID=BAAI/bge-m3
EMBEDDING_DIM=1024
RERANKER_MODEL_ID=BAAI/bge-reranker-base
WHISPER_MODEL_ID=Systran/faster-whisper-large-v2
DIARIZATION_MODEL_ID=pyannote-community/speaker-diarization-community-1
RESUME_MILVUS_COLLECTION=interview_copilot_resume
TTS_DEFAULT_VOICE=zh-CN-YunxiNeural

# RAG and agent tuning
VECTOR_TOP_K=8
BM25_TOP_K=8
FUSION_TOP_K=6
RERANK_TOP_N=5
RAG_MIN_SCORE=0.5
RAG_FALLBACK_MIN_SCORE=0.02
RAG_LEXICAL_FALLBACK_MIN_OVERLAP=0.35
ANALYSIS_CHUNK_TOKEN_LIMIT=12000
AGENT_MAX_STEPS=25
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_OBSERVATION_CHAR_LIMIT=6000
AGENT_TEMPERATURE=0.2
AGENT_MAX_RUNTIME_SECONDS=180
AGENT_MAX_TOTAL_TOKENS=200000
AGENT_MAX_RESPONSE_TOKENS=4096
AGENT_MAX_TOOL_CALLS=50
AGENT_MAX_CALLS_PER_TOOL=8
AGENT_TOOL_SCHEMA_STRICT=true
AGENT_MAX_TOOL_ARG_CHARS=4000

# Lever job-search tool defaults
LEVER_API_BASE=https://api.lever.co/v0
LEVER_SITES=openai
LEVER_DEFAULT_LIMIT=30

# Agent web search (optional — web_search tool disabled without this key)
TAVILY_API_KEY=

# Evaluation
EVAL_LIMIT=200
EVAL_CONCURRENCY=4
EVAL_RELEVANCE_THRESHOLD=0.15
EVAL_TIMEOUT_SECONDS=60
EVAL_FORCE_REBUILD=0
RAGAS_CHUNK_SIZE=10
RAGAS_MAX_WORKERS=32

# Database connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
