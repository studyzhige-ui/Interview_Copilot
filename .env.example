# =============================================================================
#  Interview Copilot — Full-mode environment template
#
#  Local-models build: embedding / reranker / ASR run on this machine.
#  LLM is still cloud (your choice of vendor below).
#
#  Usage:
#    cp .env.example .env        # Linux / macOS
#    Copy-Item .env.example .env # Windows PowerShell
#  Then fill the keys marked [required]. Other sections have sensible
#  defaults that work out of the box with the bundled docker-compose.
#
#  Never commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# § 1. Security
# -----------------------------------------------------------------------------
# [required] Used for JWT signing AND Fernet encryption of stored user API
# keys. Rotating it invalidates every user's saved provider key.
#
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Comma-separated previous SECRET_KEYs kept around for in-flight Fernet
# rotation. Move the old SECRET_KEY here, set a new one above, restart,
# and the app will lazily re-encrypt every user_api_keys row under the
# new primary on first read.
SECRET_KEYS_OLD=


# -----------------------------------------------------------------------------
# § 2. Core service URLs
#     Defaults match the bundled docker-compose containers.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_copilot
REDIS_URL=redis://localhost:6379/0
MILVUS_URI=http://localhost:19530

# Frontend origins allowed by CORS (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Reverse-proxy trust list (comma-separated IPs; "*" trusts all).
# Leave EMPTY in dev (direct connect). In prod (behind nginx / ALB /
# CDN) you MUST set this to the proxy IP(s), otherwise every
# request's client.host collapses to the proxy IP — slowapi's per-IP
# rate-limit and the verification-code IP-lockout both degrade to a
# single global counter, and one attacker can burn the 5/min auth
# quota for everyone. The app logs a [PRODUCTION BLOCKER] ERROR at
# startup when SENTRY_ENVIRONMENT is prod-like and this is empty.
#
# Single-layer nginx on the same host: TRUSTED_PROXIES=127.0.0.1
# Behind a CDN (e.g. Cloudflare→nginx→app): set to the nginx IP
#   AND configure nginx with ``proxy_set_header X-Forwarded-For
#   $remote_addr;`` (NOT $proxy_add_x_forwarded_for) so the rightmost
#   XFF entry is the real client and not nginx itself.
TRUSTED_PROXIES=

# JWT lifetimes in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080


# -----------------------------------------------------------------------------
# § 3. Object storage (S3-compatible)
#     Defaults match the bundled MinIO (minioadmin / minioadmin).
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=interview-copilot-bucket


# -----------------------------------------------------------------------------
# § 3.5. SMTP — email verification codes
#     Leave SMTP_HOST empty to fall back to "print code to stdout" (dev mode).
#     Filled → real email gets sent AND the body is mirrored to the backend
#     log for traceability either way.
#
#     Gmail:   smtp.gmail.com  :587  Requires a 16-char "App Password" (NOT
#              your login password). Enable 2FA first, then create one at
#              https://myaccount.google.com/apppasswords
#     163:     smtp.163.com    :465  Settings → POP3/SMTP/IMAP → enable SMTP
#              → generate "client authorization code".
#     QQ:      smtp.qq.com     :465  Settings → Account → POP3/IMAP/SMTP →
#              enable service → generate authorization code.
#     Outlook: smtp-mail.outlook.com :587  Use your account password (or
#              an app password if 2FA is on).
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Interview Copilot <noreply@example.com>
SMTP_USE_TLS=true                  # true for :587 (STARTTLS); false for :465 (SSL)


# -----------------------------------------------------------------------------
# § 3.6. LangSmith — LLM call tracing (optional)
#     Sign up at https://smith.langchain.com → Settings → API Keys, then
#     paste the key here and flip LANGSMITH_TRACING=true. Every OpenAI-SDK
#     call (LLM completions, streaming, function calls) is reported with
#     full prompts, responses, tokens, and latency for debugging.
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=interview-copilot-dev
LANGSMITH_TRACING=false


# -----------------------------------------------------------------------------
# § 4. LLM provider keys — fill at least one. Empty keys are skipped silently.
#     Per-user keys configured from the frontend "Models" page override
#     these (encrypted DB storage). These env values are the project-wide
#     fallback / single-user default.
# -----------------------------------------------------------------------------

# DeepSeek — cheap, strong, China-friendly. The default starter.
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# OpenAI
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Alibaba DashScope (Qwen)
# https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# Moonshot (Kimi)
# https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# Zhipu (GLM)
# https://bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# Xiaomi MiMo
MIMO_API_KEY=

# Google Gemini (via the OpenAI-compatible endpoint)
GOOGLE_API_KEY=

# NVIDIA API Catalog — hosts open-weights mirrors (Llama, Qwen, Gemma, …).
# https://build.nvidia.com/
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1


# -----------------------------------------------------------------------------
# § 5. Embedding / Reranker / ASR provider keys
#     Full mode runs these locally so usually empty. Only fill if you
#     switch the *_PROVIDER below to a cloud vendor.
# -----------------------------------------------------------------------------

# SiliconFlow — one account covers embedding + reranker + ASR.
# https://siliconflow.cn
SILICONFLOW_API_KEY=

# Jina AI — embedding + reranker.
# https://jina.ai/
JINA_API_KEY=

# Cohere — reranker.
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=


# -----------------------------------------------------------------------------
# § 6. Strongly recommended external services
#     Technically optional with graceful fallback, but the UX hit when
#     these are empty is real.
# -----------------------------------------------------------------------------

# LlamaCloud LlamaParse — high-quality PDF/DOCX parsing for resumes and
# the knowledge library. Empty → falls back to PyMuPDF, which is fine for
# clean text PDFs but loses structure / drops fields on scanned or
# multi-column resumes.
# Sign up:  https://cloud.llamaindex.ai/api-key  (free 1k pages/month)
LLAMA_CLOUD_API_KEY=

# Tavily — web search tool used by Agent mode. Empty → web_search is
# disabled and the Agent can only answer from training data + local docs.
# Sign up:  https://tavily.com/  (free 1k searches/month)
TAVILY_API_KEY=


# -----------------------------------------------------------------------------
# § 7. Model role assignment
#     Full mode keeps embedding / reranker / ASR local. Swap any
#     *_PROVIDER + *_MODEL pair to go cloud. See docs/providers.md.
# -----------------------------------------------------------------------------

# HuggingFace mirror for local downloads. CN mirror by default; set to
# https://huggingface.co for the global endpoint.
HF_ENDPOINT=https://hf-mirror.com

# ── Embedding (RAG vector search) ────────────────────────────────────────────
# EMBEDDING_DIM MUST match the model's actual output dim. Switching to a
# different-dim model after data is indexed requires dropping the Milvus
# collection and rebuilding the index.
#
# Recommended combos:
#   local       BAAI/bge-m3                  dim=1024  (default)
#   local       BAAI/bge-large-zh-v1.5       dim=1024
#   local       BAAI/bge-small-en-v1.5       dim=384   (fastest, lower quality)
#   siliconflow BAAI/bge-m3                  dim=1024
#   openai      text-embedding-3-small       dim=1536
#   jina        jina-embeddings-v3           dim=1024
#   dashscope   text-embedding-v3            dim=1024
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=auto              # auto | cuda | cpu

# ── Reranker (RAG cross-encoder) ────────────────────────────────────────────
# Recommended:
#   local        BAAI/bge-reranker-v2-m3                  (default)
#   local        BAAI/bge-reranker-large
#   siliconflow  BAAI/bge-reranker-v2-m3
#   jina         jina-reranker-v2-base-multilingual
#   cohere       rerank-multilingual-v3.0
RERANKER_PROVIDER=local
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── ASR (audio transcription) ───────────────────────────────────────────────
# Recommended:
#   local_whisperx  Systran/faster-whisper-large-v3   (default, needs GPU for speed)
#   local_whisperx  Systran/faster-whisper-medium
#   local_whisperx  Systran/faster-whisper-small      (fastest, lower quality)
#   openai          whisper-1                         (cloud, word-level timestamps)
#   openai          gpt-4o-transcribe
#   siliconflow     FunAudioLLM/SenseVoiceSmall       (cloud, cheap)
TRANSCRIPTION_PROVIDER=local_whisperx
TRANSCRIPTION_MODEL=Systran/faster-whisper-large-v3

# ── Speaker diarization ─────────────────────────────────────────────────────
# auto      = enable Pyannote when ASR is local_whisperx; otherwise off.
# pyannote  = HYBRID mode: remote ASR + local Pyannote labels. Requires the
#             ASR provider to return word-level timestamps (openai/whisper-1
#             does). Run `python scripts/init_models.py --only diarization`
#             once to fetch the model (~17 MB).
# none      = always single-speaker transcript.
DIARIZATION_MODE=auto
DIARIZATION_MODEL_ID=pyannote-community/speaker-diarization-community-1
# pyannote-community/speaker-diarization-community-1  — no HF token needed.
# pyannote/speaker-diarization-3.1                    — needs HF_TOKEN + license accept.

# ── TTS (text-to-speech) ────────────────────────────────────────────────────
# Voice used by edge-tts in mock interviews. Full voice list:
# https://speech.platform.bing.com/consumer/speech/synthesize/readaloud/voices/list
TTS_DEFAULT_VOICE=zh-CN-YunxiNeural

# ── LLM role routing ────────────────────────────────────────────────────────
# Three user-facing roles (primary / agent / mock_interview, plus internal
# back-compat alias ``fast``) map to specific ``{provider}/{model_id}``
# profile ids. The active assignment is persisted per user in
# ``users.model_selection_json``; the frontend "Models" page edits it at
# runtime. No env var needed here — kept for back-compat with old setups.
MODEL_SELECTION_FILE=


# -----------------------------------------------------------------------------
# § 8. Error reporting (Sentry — optional)
#     Empty SENTRY_DSN disables Sentry entirely. Get a DSN at
#     https://sentry.io → Project Settings → Client Keys.
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local           # local / staging / prod
SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional: set to your git SHA on each deploy so issues group per release.
SENTRY_RELEASE=


# -----------------------------------------------------------------------------
# § 9. Milvus tuning
#     Defaults are fine; tweak only for at-scale perf work.
# -----------------------------------------------------------------------------
MILVUS_COLLECTION=interview_copilot_rag
MILVUS_SIMILARITY_METRIC=IP
MILVUS_DENSE_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_HNSW_EF_SEARCH=64
# MEMORY_MILVUS_COLLECTION / MEMORY_VECTOR_TOP_K / MEMORY_LEXICAL_TOP_K
# / MEMORY_FINAL_TOP_K / MEMORY_BACKFILL_ON_STARTUP belonged to the
# retired v2 memory_items + Milvus path. v3 memory is markdown docs in
# Postgres; no vector store, no top-k tuning. Settings.extra='ignore'
# tolerates these in old env files but they have no effect.
RESUME_MILVUS_COLLECTION=interview_copilot_resume


# -----------------------------------------------------------------------------
# § 10. RAG / Agent tuning (advanced)
# -----------------------------------------------------------------------------
VECTOR_TOP_K=8
BM25_TOP_K=8
FUSION_TOP_K=6
RERANK_TOP_N=5
RAG_MIN_SCORE=0.5
RAG_FALLBACK_MIN_SCORE=0.02
RAG_LEXICAL_FALLBACK_MIN_OVERLAP=0.35

AGENT_MAX_STEPS=25
AGENT_TOOL_TIMEOUT_SECONDS=30
AGENT_TEMPERATURE=0.2
AGENT_MAX_RUNTIME_SECONDS=180
AGENT_MAX_TOTAL_TOKENS=200000
AGENT_MAX_RESPONSE_TOKENS=4096
AGENT_MAX_TOOL_CALLS=50
AGENT_MAX_CALLS_PER_TOOL=8
AGENT_TOOL_SCHEMA_STRICT=true
AGENT_MAX_TOOL_ARG_CHARS=4000
AGENT_PERSIST_THRESHOLD=30000
AGENT_TURN_BUDGET_CHARS=100000
AGENT_PERSIST_PREVIEW_SIZE=1500


# -----------------------------------------------------------------------------
# § 11. Database connection pool
# -----------------------------------------------------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800


# -----------------------------------------------------------------------------
# § 12. Runtime data paths
#     Empty = use the default layout under data/.
# -----------------------------------------------------------------------------
APP_DATA_DIR=
DB_DIR=
CHROMA_DB_DIR=
DOCSTORE_DIR=
CACHE_DIR=
LOG_DIR=
EVAL_DIR=
STORAGE_DIR=


# -----------------------------------------------------------------------------
# § 13. Docker-network URL overrides
#     Only matter when api/worker run INSIDE docker-compose (--profile full).
#     Defaults match the bundled .env.docker credentials; only set these
#     if you actually customised .env.docker.
# -----------------------------------------------------------------------------
# DATABASE_URL_DOCKER=postgresql://postgres:postgres@db:5432/interview_copilot
# REDIS_URL_DOCKER=redis://redis:6379/0
# MILVUS_URI_DOCKER=http://milvus-standalone:19530
# AWS_ENDPOINT_URL_DOCKER=http://minio:9000
# UVICORN_WORKERS=2


# -----------------------------------------------------------------------------
# § 14. Evaluation suite (optional)
# -----------------------------------------------------------------------------
EVAL_LIMIT=200
EVAL_CONCURRENCY=4
EVAL_RELEVANCE_THRESHOLD=0.15
EVAL_TIMEOUT_SECONDS=60
EVAL_FORCE_REBUILD=0
RAGAS_CHUNK_SIZE=10
RAGAS_MAX_WORKERS=32


# -----------------------------------------------------------------------------
# § 15. Third-party job APIs (Agent tool, optional)
# -----------------------------------------------------------------------------
LEVER_API_BASE=https://api.lever.co/v0
LEVER_SITES=openai
LEVER_DEFAULT_LIMIT=30
