```python
class CompactionService:
    """
    会话压缩服务 (OpenClaw Layer 3)
    当上下文超限时，将旧对话压缩为 Working State Summary。
    """

    async def compact_if_needed(self, session_id: str) -> bool:
        """
        检查是否需要压缩。如果需要：
        1. 取 compaction_cursor 之前到窗口边界的消息
        2. 生成 Working State Summary（保留 5 类关键信息）
        3. 更新 compaction_cursor
        4. 更新 working_state 字段
        """

    COMPACTION_PROMPT = """
    你是一个精准的工作状态压缩器。请将以下旧的工作状态和新对话合并为结构化的工作状态摘要。

    【必须保留的 5 类信息】（按优先级排序）：
    1. 当前目标：用户当前正在准备什么、想解决什么
    2. 当前进度：最近讨论到了哪个知识点、哪一步
    3. 已决定方案：用户确认的学习路径、偏好的回答风格
    4. 未完成事项：提出但未深入的追问、待解决的疑惑
    5. 关键约束：用户的技术栈背景、目标公司/岗位、时间限制

    【绝对禁令】：
    - 不要保留具体的技术知识点原文（那些在 RAG 知识库里已经有了）
    - 不要保留闲聊内容
    - 只输出压缩后的结构化摘要正文
    """


class MemoryExtractionService:
    """
    长期记忆提取服务 (Claude Code 式异步子 Agent)
    在一轮对话结束后，异步判断是否有值得沉淀为长期记忆的信息。
    """

    async def extract_if_worthy(self, session_id: str, user_id: str,
                                 new_messages: list[dict]) -> list[MemoryItem]:
        """
        异步后台运行：
        1. 分析本轮新消息
        2. 判断是否出现了长期有价值的信息（偏好/短板/背景/反馈）
        3. 如果有，创建或更新 MemoryItem
        4. 如果没有，静默返回空列表

        保护机制（借鉴 Claude Code）：
        - 只读对话记录，不修改任何会话数据
        - 只往 memory_items 表写入
        - 有节流：不是每轮都强跑，可配置间隔
        - 成功才推进游标，失败不推进
        """

    EXTRACTION_PROMPT = """
    你是一个记忆提取分析器。请审视以下最新的对话片段，判断是否出现了值得跨会话长期保存的信息。

    【只有以下 4 种类型的信息值得提取】：
    - user: 用户背景、能力水平、技术栈偏好
    - feedback: 用户对交互方式的明确反馈（如"请简洁一些"、"多给追问"）
    - weakness: 多次暴露的技术短板（如"又答错了 Redis cluster 的迁移"）
    - reference: 外部资源或项目背景信息

    【绝对不要提取】：
    - 已在 RAG 知识库中的技术知识
    - 临时的单次问答细节
    - 当前会话的任务进度（那属于 working state）

    如果本轮没有值得长期保存的信息，直接输出空 JSON 数组 []。
    """


class MemoryRetrievalService:
    """
    长期记忆检索服务 (Claude Code 式 index-based selective recall)
    根据当前 query 从 memory index 中召回最相关的少量条目。
    """

    async def recall_relevant(self, user_id: str, query: str,
                               max_items: int = 5) -> list[MemoryItem]:
        """
        四步流水线召回 (Claude Code Active Recall 机制)：

        Step 1 - 扫描(Scan)：从 DB 加载用户所有记忆的元数据
                 (id/type/description/updated_at)，零模型调用
        Step 2 - 摘要(Summarize)：将元数据拼成 "目录清单" 文本
        Step 3 - 选择(Select)：用快速模型从目录清单中精选 ≤5 条，
                 明确要求 "只选确定有用的"（宁缺毋滥原则）
        Step 4 - 注入(Inject)：只读被选中条目的正文，
                 单条限制 4KB，超过截断

        额外机制：
        - 过期警告：超过 2 天的记忆自动附加 "这是 X 天前的快照" 提示
        - 更新被召回条目的 recall_count（OpenClaw promotion signal）

        成本控制：
        - 第一阶段元数据粗筛（零模型调用）
        - 第二阶段便宜模型精选
        - 总注入量从 "全文几十万字节" 降至 "<3万字节"
        """

    async def get_memory_index(self, user_id: str) -> list[dict]:
        """获取用户的所有记忆条目索引（只含 id/type/description/updated_at）"""
```

