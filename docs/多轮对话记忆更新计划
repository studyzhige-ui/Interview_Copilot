class ContextAssemblyPipeline:
    """
    上下文装配管线 (OpenClaw Layer 2)
    职责：从 transcript 和 memory 中组装当前轮要送给模型的上下文。
    实现 sanitize → truncate → repair → assemble 四步流水线。
    """

    async def assemble_context(self, session_id: str, user_id: str,
                                current_query: str) -> AssembledContext:
        """
        核心方法：组装当前轮的完整上下文。

        返回 AssembledContext:
          - working_state: str         # 压缩态的历史工作状态
          - recent_turns: list[dict]   # 经过截断和修复的近期对话
          - relevant_memories: list    # 按需召回的长期记忆条目
          - context_text: str          # 最终拼装好的上下文字符串
        """

    def _sanitize(self, messages: list[dict]) -> list[dict]:
        """清洗：过滤系统内部标记、heartbeat、空消息"""

    def _truncate(self, messages: list[dict], max_tokens: int) -> list[dict]:
        """截断：按 token 预算从旧到新截断，保证最新消息优先"""

    def _repair_pairs(self, messages: list[dict]) -> list[dict]:
        """修复：确保 User/Agent 消息成对出现，截断不会产生孤立消息"""

    def _assemble(self, working_state: str, recent_turns: list[dict],
                   relevant_memories: list, current_query: str) -> str:
        """
        最终拼装，顺序固定（稳定前缀，动态后缀 — prompt cache friendly）:
        1. [STABLE PREFIX] System Instructions
        2. [STABLE PREFIX] Working State Summary
        3. [DYNAMIC SUFFIX] Relevant Long-term Memories
        4. [DYNAMIC SUFFIX] Recent Conversation Turns
        5. [DYNAMIC SUFFIX] Current Query
        """
```

